# Dependencies
node_modules/

# Build output
dist/
out/
release/
*.tsbuildinfo

# electron-builder resources directory (icons, etc.) is tracked, but
# nothing in there right now — placeholder icon goes here when we ship.

# Local databases (Cairn writes cairn.db to userData; these patterns catch
# stray local copies and SQLite journals)
*.sqlite
*.sqlite-journal
*.db
*.db-journal

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Syncthing transients (partial / staging files while a sync is in flight)
.syncthing.*
*.sync-conflict-*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# electron-builder artifacts
app-builds/

# Alpine source — checked out alongside the project as a reference (see
# CLAUDE.md). Not part of Cairn; do not commit.
/alpine-*/
